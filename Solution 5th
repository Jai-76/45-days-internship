# 10. Using Pandas built-in plotting to build a dataset with at least 4 numeric columns
# Creating dummy dataset containing Midterm, Endterm, Practical, and Assignment Marks for 100 students
np.random.seed(10)
df_viz = pd.DataFrame({
    'Midterm': np.random.randint(40, 100, 100),
    'Endterm': np.random.randint(50, 100, 100),
    'Practical': np.random.randint(60, 100, 100),
    'Assignment': np.random.randint(70, 100, 100),
    'Stream': np.random.choice(['Science', 'Commerce', 'Arts'], 100)
})

# Setup multi-plot layout
fig, axes = plt.subplots(1, 3, figsize=(15, 5))

# A histogram for marks distribution
df_viz['Endterm'].plot(kind='hist', ax=axes[0], bins=10, color='darkorange', edgecolor='black', alpha=0.7)
axes[0].set_title("Endterm Marks Distribution")
axes[0].set_xlabel("Marks Range")

# A box plot to visualize spread and outliers
df_viz[['Midterm', 'Endterm', 'Practical', 'Assignment']].plot(kind='box', ax=axes[1], color=dict(boxes='darkblue', whiskers='black', medians='red'))
