print("\n--- Question 6: Handling Missing Data ---")
# 6. Create a DataFrame with intentionally placed missing values
missing_data = {
    'Name': ['Aarav', 'Ananya', 'Vihaan', 'Diya', 'Kabir', 'Ishaan'],
    'Age': [20, 21, 19, 22, 20, 21],
    'Marks': [85, np.nan, 90, 68, np.nan, 55],  # Missing marks
    'City': ['Jaipur', 'Delhi', np.nan, 'Jaipur', 'Delhi', np.nan] # Missing cities
}
df_missing = pd.DataFrame(missing_data)
print("DataFrame with missing values:")
print(df_missing)

# Identify missing values using isnull()
print("\nMissing Value Locations (isnull):")
print(df_missing.isnull())

# Fill missing marks with the column mean
mean_marks = df_missing['Marks'].mean()
df_missing['Marks'] = df_missing['Marks'].fillna(mean_marks)
print(f"\nMissing Marks filled with Mean ({mean_marks:.2f}):")
print(df_missing)

# Drop rows where City is missing using dropna()
df_cleaned = df_missing.dropna(subset=['City'])
print("\nDataFrame after dropping rows where 'City' was missing:")
print(df_cleaned)


