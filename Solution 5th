print("\n--- Question 2: 4x4 Matrix Operations ---")
# 2. Create a 4x4 matrix using NumPy.
matrix_4x4 = np.random.randint(1, 50, size=(4, 4))
print(f"Original 4x4 Matrix:\n{matrix_4x4}")

# Extract the diagonal elements
diagonal = np.diag(matrix_4x4)
print(f"Diagonal Elements: {diagonal}")

# Replace all even numbers with 0 (modifying a copy to keep original intact)
matrix_mod = matrix_4x4.copy()
matrix_mod[matrix_mod % 2 == 0] = 0
print(f"Matrix with Even Numbers Replaced by 0:\n{matrix_mod}")

# Find the index of the maximum value using argmax()
max_index_flat = np.argmax(matrix_4x4)
# Convert flat index back to 2D matrix coordinates
max_index_2d = np.unravel_index(max_index_flat, matrix_4x4.shape)
print(f"Flat index of maximum value: {max_index_flat}")
print(f"2D coordinates (Row, Col) of maximum value: {max_index_2d} (Value: {matrix_4x4[max_index_2d]})")


