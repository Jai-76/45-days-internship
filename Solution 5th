# 11. Using Seaborn, create a dataset of at least 50 records with columns Age, Salary, Department, Experience
np.random.seed(24)
records = 60
departments_list = ['HR', 'Engineering', 'Marketing', 'Sales']

salary_data = {
    'Age': np.random.randint(22, 60, size=records),
    'Salary': np.random.randint(30000, 150000, size=records),
    'Department': np.random.choice(departments_list, size=records),
    'Experience': np.random.randint(1, 35, size=records)
}
df_seaborn = pd.DataFrame(salary_data)

# Create structural subplots for Seaborn
fig, axes = plt.subplots(1, 3, figsize=(18, 5))

# A scatter plot of Age vs Salary with hue as Department
sns.scatterplot(data=df_seaborn, x='Age', y='Salary', hue='Department', palette='deep', s=100, ax=axes[0])
axes[0].set_title("Age vs Salary by Department")

# A heatmap showing correlation between numeric columns
numeric_corr = df_seaborn[['Age', 'Salary', 'Experience']].corr()
sns.heatmap(numeric_corr, annot=True, cmap='coolwarm', fmt=".2f", linewidths=.5, ax=axes[1])
axes[1].set_title("Correlation Heatmap")

# A bar plot showing average Salary per Department
sns.barplot(data=df_seaborn, x='Department', y='Salary', errorbar=None, palette='muted', hue='Department', legend=False, ax=axes[2])
axes[2].set_title("Average Salary per Department")

plt.tight_layout()
plt.savefig('plot_q11_seaborn_plots.png', dpi=150)
plt.close()
print("-> Saved: plot_q11_seaborn_plots.png")


# 12. Create a subplot layout of 2 rows x 2 columns using Matplotlib
# Let's generate a single, consistent dataset for this task
x_data = np.linspace(1, 50, 50)
y_linear = 2.5 * x_data + np.random.normal(0, 10, 50)  # Linear relationship with noise

fig, axs = plt.subplots(2, 2, figsize=(14, 10))

# 1. Line plot
axs[0, 0].plot(x_data, y_linear, color='blue', linestyle='-', marker='s', markersize=4, alpha=0.7)
axs[0, 0].set_title("Line Plot (Trend Line)")
axs[0, 0].set_xlabel("X-Axis")
axs[0, 0].set_ylabel("Y-Axis")
axs[0, 0].grid(True)

# 2. Scatter plot
axs[0, 1].scatter(x_data, y_linear, color='crimson', edgecolor='black', alpha=0.8, s=50)
axs[0, 1].set_title("Scatter Plot (Data Points)")
axs[0, 1].set_xlabel("X-Axis")
axs[0, 1].set_ylabel("Y-Axis")
axs[0, 1].grid(True)

# 3. Bar chart (aggregated down to sample buckets to make a clean bar presentation)
categories = ['Group A', 'Group B', 'Group C', 'Group D', 'Group E']
values = [y_linear[0:10].mean(), y_linear[10:20].mean(), y_linear[20:30].mean(), y_linear[30:40].mean(), y_linear[40:50].mean()]
axs[1, 0].bar(categories, values, color='forestgreen', edgecolor='black', alpha=0.75)
axs[1, 0].set_title("Bar Chart (Category Means)")
axs[1, 0].set_xlabel("Groups")
axs[1, 0].set_ylabel("Average Value")
axs[1, 0].grid(axis='y')

# 4. Histogram
axs[1, 1].hist(y_linear, bins=8, color='gold', edgecolor='black', alpha=0.8)
axs[1, 1].set_title("Histogram (Value Distribution)")
axs[1, 1].set_xlabel("Value Ranges")
axs[1, 1].set_ylabel("Frequency")
axs[1, 1].grid(True)

# Main super title
plt.suptitle("Combined Dataset Visualizations (2x2 Layout)", fontsize=16, fontweight='bold', y=0.98)

plt.tight_layout()
plt.savefig('plot_q12_subplots_2x2.png', dpi=150)
plt.close()
print("-> Saved: plot_q12_subplots_2x2.png")

