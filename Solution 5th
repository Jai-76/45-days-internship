# A pie chart showing category-wise percentage
df_viz['Stream'].value_counts().plot(kind='pie', ax=axes[2], autopct='%1.1f%%', colors=['#ff9999','#66b3ff','#99ff99'], startangle=90)
axes[2].set_title("Stream-wise Percentage")
axes[2].set_ylabel("") # Remove default y-label

plt.tight_layout()
plt.savefig('plot_q10_pandas_plots.png', dpi=150)
plt.close()
